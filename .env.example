# Copy to .env and fill in values. Never commit .env.
# Used for local runs and reference; in AWS, set env via docker run -e or task definition.

# ---- Backend services (customer_service, book_service) ----
DB_HOST=localhost
DB_USER=app
DB_PASSWORD=your_db_password
DB_NAME=bookstore

# ---- BFF services (web_bff, mobile_bff) ----
URL_BASE_BACKEND_SERVICES=http://localhost:3000

# ---- Optional: JWT secret (if you enable signature verification in shared/jwt_utils.py) ----
# JWT_SECRET=your-secret
